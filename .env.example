# Firebase Authentication (optioneel)
# Maak een project op https://console.firebase.google.com → Projectinstellingen → Jouw apps → Web-app
# Authentication: schakel E-mail/wachtwoord en Google-provider in.
# Voeg geautoriseerde domeinen toe (localhost, jouw productiedomein).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google Sign-in (optioneel, aanbevolen i.p.v. alleen popup): Web client-ID uit Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs.
# Zelfde ID als in Firebase Console → Authentication → Sign-in method → Google → Web client ID.
# Het client secret (begint meestal met GOCSPX-) hoort alleen in Firebase bij de Google-provider, niet in Vite of de frontend.
VITE_GOOGLE_OAUTH_CLIENT_ID=
